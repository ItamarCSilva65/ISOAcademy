{{#unless isFullList}}
<section class="hero-banner">
    <div class="hero-text">
        <h1 data-i18n="hero_title">Domine as Normas ISO</h1>
        <p data-i18n="hero_sub">Eleve sua carreira com certificações internacionais.</p>
        <a href="/cursos_em_destaque" class="btn btn-accent" data-i18n="hero_btn">Ver Cursos em Destaque</a>
    </div>
</section>
{{/unless}}

<section id="cursos-lista" class="courses-section">
    <h2 class="section-title">
        {{#if isFullList}}
        <span data-i18n="sec_allcourses">Catálogo Completo</span>
        {{else}}
        <span data-i18n="sec_highlights">Cursos em Destaque</span>
        {{/if}}
    </h2>

    {{#if isFullList}}
    <form method="GET" action="/cursos" class="catalog-filter-bar">
        <div class="filter-group">
            <label for="filter-categoria" data-i18n="filter_category_label">Categoria</label>
            <select id="filter-categoria" name="categoria">
                <option value="" data-i18n="filter_category_all">Todas as categorias</option>
                {{#each categoryOptions}}
                <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                {{/each}}
            </select>
        </div>

        <div class="filter-group">
            <label for="filter-nivel" data-i18n="filter_level_label">Nível</label>
            <select id="filter-nivel" name="nivel">
                <option value="" data-i18n="filter_level_all">Todos os níveis</option>
                {{#each levelOptions}}
                <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                {{/each}}
            </select>
        </div>

        <div class="filter-group">
            <label for="filter-faixa-preco" data-i18n="filter_price_label">Faixa de Preço</label>
            <select id="filter-faixa-preco" name="faixa_preco">
                <option value="" data-i18n="filter_price_all">Todas as faixas</option>
                {{#each priceOptions}}
                <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                {{/each}}
            </select>
        </div>

        <div class="filter-actions">
            <button type="submit" class="btn btn-primary" data-i18n="filter_apply">Aplicar filtros</button>
            {{#if filters.hasActive}}
            <a href="/cursos" class="btn btn-outline-secondary" data-i18n="filter_clear">Limpar</a>
            {{/if}}
        </div>
    </form>

    <p class="catalog-filter-summary" data-i18n-template="catalog_summary" data-count-filtered="{{totalFiltered}}" data-count-total="{{totalCourses}}">
        Exibindo {{totalFiltered}} de {{totalCourses}} cursos.
    </p>

    {{#if filters.hasActive}}
    <div class="active-filter-chips" aria-label="Filtros ativos" data-i18n-aria-label="filter_active_aria">
        {{#each activeFilterChips}}
        <span class="filter-chip">{{this.label}}</span>
        {{/each}}
    </div>
    {{/if}}
    {{/if}}

    <div class="grid-courses">
        {{#each courses}}
        <article class="course-card">
            <div class="card-image">
                {{#if this.destaque}}
                <span class="badge-destaque" data-i18n="badge_bestseller">Mais Vendido</span>
                {{/if}}
                <img src="{{this.img}}" alt="{{t this.nome ../lang}}">
            </div>
            <div class="card-content">
                <h3>{{t this.nome ../lang}}</h3>
                <p class="course-subtitle">{{t this.titulo_completo ../lang}}</p>
                <div class="card-footer">
                    <span class="price">{{formatCurrency this.preco}}</span>
                    <a href="/curso/{{this.id}}" class="btn btn-primary" data-i18n="btn_details">Ver Detalhes</a>
                </div>
            </div>
        </article>
        {{else}}
        <p class="catalog-empty" data-i18n="catalog_empty">Nenhum curso encontrado para os filtros selecionados.</p>
        {{/each}}
    </div>

    {{#unless isFullList}}
    <div style="text-align: center; margin-top: 50px;">
        <a href="/cursos" class="btn btn-primary btn-large" data-i18n="btn_viewall">Ver Todos os Cursos</a>
    </div>
    {{/unless}}
</section>