<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <!-- Bootstrap 5 Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark iso-navbar sticky-top">
        <div class="container-fluid px-4">

            <!-- Logo -->
            <a class="navbar-brand iso-logo me-4" href="/">ISO<strong>Academy</strong></a>

            <!-- Hamburguer mobile -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                aria-controls="mainNavbar" aria-expanded="false" aria-label="Abrir menu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Links + Idioma + Acessibilidade -->
            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 align-items-lg-center">
                    <li class="nav-item"><a class="nav-link px-2 text-nowrap" href="/" data-i18n="nav_home">Home</a>
                    </li>
                    <li class="nav-item"><a class="nav-link px-2 text-nowrap" href="/cursos_gratuitos"
                            data-i18n="nav_free">Cursos Gratuitos</a></li>
                    <li class="nav-item"><a class="nav-link px-2 text-nowrap" href="/cursos" data-i18n="nav_all">Todos
                            os Cursos</a></li>
                    <li class="nav-item"><a class="nav-link px-2 text-nowrap" href="/cursos_in_company"
                            data-i18n="nav_incompany">In Company</a></li>
                    <li class="nav-item"><a class="nav-link px-2 text-nowrap" href="/cursos_em_destaque"
                            data-i18n="nav_highlights">Destaques</a></li>
                    <li class="nav-item">
                        <a class="nav-link px-2 text-nowrap" href="/carrinho">
                            <span class="badge bg-warning text-dark me-1">🛒</span><span
                                data-i18n="nav_cart">Carrinho</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-outline-light btn-sm px-3 ms-1 text-nowrap" href="/login"
                            data-i18n="nav_login">🔑 Login</a>
                    </li>
                </ul>

                <!-- Seletor de Idioma -->
                <div class="dropdown me-2">
                    <button id="langDropdownBtn" class="btn btn-sm btn-outline-info dropdown-toggle text-nowrap"
                        type="button" data-bs-toggle="dropdown" aria-expanded="false" data-i18n="nav_language">
                        🌐 Idioma
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <button class="dropdown-item lang-option" data-lang="pt" onclick="applyLang('pt')">
                                🇧🇷 Português
                            </button>
                        </li>
                        <li>
                            <button class="dropdown-item lang-option" data-lang="en" onclick="applyLang('en')">
                                🇺🇸 English
                            </button>
                        </li>
                        <li>
                            <button class="dropdown-item lang-option" data-lang="fr" onclick="applyLang('fr')">
                                🇫🇷 Français
                            </button>
                        </li>
                        <li>
                            <button class="dropdown-item lang-option" data-lang="es" onclick="applyLang('es')">
                                🇪🇸 Español
                            </button>
                        </li>
                        <li>
                            <button class="dropdown-item lang-option" data-lang="de" onclick="applyLang('de')">
                                🇩🇪 Deutsch
                            </button>
                        </li>
                        <li>
                            <button class="dropdown-item lang-option" data-lang="zh" onclick="applyLang('zh')">
                                🇨🇳 中文
                            </button>
                        </li>
                        <li>
                            <button class="dropdown-item lang-option" data-lang="ar" onclick="applyLang('ar')">
                                🇸🇦 العربية
                            </button>
                        </li>
                        <li>
                            <button class="dropdown-item lang-option" data-lang="ja" onclick="applyLang('ja')">
                                🇯🇵 日本語
                            </button>
                        </li>
                        <li>
                            <button class="dropdown-item lang-option" data-lang="hi" onclick="applyLang('hi')">
                                🇮🇳 हिन्दी
                            </button>
                        </li>
                    </ul>
                </div>

                <!-- Acessibilidade -->
                <div class="d-flex align-items-center gap-1" id="accessibilityBar">
                    <button id="fontIncrease" class="btn btn-sm btn-outline-light" aria-label="Aumentar fonte"
                        title="Aumentar fonte">A+</button>
                    <button id="fontDecrease" class="btn btn-sm btn-outline-light" aria-label="Diminuir fonte"
                        title="Diminuir fonte">A-</button>
                    <button id="highContrast" class="btn btn-sm btn-outline-warning" aria-label="Alto contraste"
                        title="Alto contraste">☼</button>
                </div>
            </div>

        </div>
    </nav>



    <!-- Aside de Navegação Secundária -->
    <aside class="side-nav" aria-label="Acesso rápido" data-i18n-aria-label="aside_quick_access">
        <a href="/sobre_nos" class="side-nav-link" title="Sobre Nós" data-i18n-title="aside_about">
            <span class="side-nav-icon">🏢</span>
            <span class="side-nav-label" data-i18n="aside_about">Sobre<br>Nós</span>
        </a>
        <a href="/nossos_numeros" class="side-nav-link" title="Nossos Números" data-i18n-title="aside_numbers">
            <span class="side-nav-icon">📊</span>
            <span class="side-nav-label" data-i18n="aside_numbers">Números</span>
        </a>
        <a href="/depoimentos" class="side-nav-link" title="Depoimentos" data-i18n-title="aside_reviews">
            <span class="side-nav-icon">💬</span>
            <span class="side-nav-label" data-i18n="aside_reviews">Depoi-<br>mentos</span>
        </a>
    </aside>

    <main class="container main-content">
        {{{body}}}
    </main>

    <footer class="main-footer">
        <div class="container footer-content">
            <div class="footer-column">
                <a href="/" class="logo logo-footer">ISO<strong>Academy</strong></a>
                <p>Especialistas em Normas Internacionais e Certificações ISO para empresas e profissionais focados na
                    excelência e qualidade.</p>
            </div>

            <div class="footer-column">
                <h3 data-i18n="footer_links">Links Rápidos</h3>
                <ul>
                    <li><a href="/sobre_nos" data-i18n="footer_about">Sobre Nós</a></li>
                    <li><a href="/nossos_numeros">Nossos Números</a></li>
                    <li><a href="/depoimentos">Depoimentos</a></li>
                    <li><a href="/cursos" data-i18n="nav_all">Todos os Cursos</a></li>
                </ul>
                <h3 style="margin-top: 15px;" data-i18n="footer_faq">FAQ</h3>
                <ul>
                    <li><a href="#" data-i18n="footer_faq1">Como funcionam as aulas?</a></li>
                    <li><a href="#" data-i18n="footer_faq2">Formas de Pagamento</a></li>
                    <li><a href="#" data-i18n="footer_faq3">Certificados</a></li>
                </ul>

                <h3 style="margin-top: 15px;">Formas de Pagamento</h3>
                <ul>
                    <li>Pagamento via PIX</li>
                    <li>Cartão de crédito à vista ou em até 4x sem juros</li>
                    <li>Cartão de crédito em até 10x com juros</li>
                    <li>Pagamento no boleto</li>
                </ul>
            </div>

            <div class="footer-column">
                <h3 data-i18n="footer_contact">Contato</h3>
                <p>📍 Avenida Gandhi, 2401-4B, Condomínio Ilha Verde, Nova Parnamirim, Parnamirim - RN - Brasil - CEP 59152-780</p>
                <p>📧 contato@isoacademy.com.br</p>
                <p>📞 +55(84) 99107-5168</p>
            </div>

            <div class="footer-column">
                <h3 data-i18n="footer_social">Redes Sociais</h3>
                <div class="social-links">
                    <a href="#" aria-label="LinkedIn">🔗 LinkedIn</a><br>
                    <a href="#" aria-label="Instagram">📸 Instagram</a><br>
                    <a href="#" aria-label="YouTube">▶️ YouTube</a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p>
                <span data-i18n="footer_copy">© 2026 ISO Academy. Todos os direitos reservados.</span>
                | <a href="#" data-i18n="footer_terms">Termos de Uso</a>
                | <a href="#" data-i18n="footer_privacy">Política de Privacidade</a>
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/i18n.js"></script>
    <script src="/js/main.js"></script>
</body>

</html>