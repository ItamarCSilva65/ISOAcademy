<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
</head>

<section class="cart-soft-page">

    <h1 class="page-title" data-i18n="cart_title">Seu Carrinho de Compras</h1>

    <div class="cart-container">
        {{#if hasItems}}
        <div class="cart-items">
            <table class="cart-table">
                <thead>
                    <tr>
                        <th data-i18n="cart_course">Curso</th>
                        <th data-i18n="cart_quantity">Quantidade</th>
                        <th data-i18n="cart_price">Preço</th>
                        <th data-i18n="cart_subtotal_label">Subtotal</th>
                        <th data-i18n="cart_action">Ação</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each cartItems}}
                    <tr>
                        <td class="cart-product-info">
                            <img src="{{this.img}}" alt="Thumb" class="cart-thumb">
                            <div>
                                <strong>{{this.nome}}</strong>
                                <br><small>{{this.titulo_completo}}</small>
                            </div>
                        </td>
                        <td>{{this.quantidade}}</td>
                        <td>{{formatCurrency this.preco}}</td>
                        <td>{{formatCurrency this.subtotal}}</td>
                        <td><a href="/carrinho?remove={{this.id}}" class="btn-remove" data-i18n="cart_remove">Remover</a></td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>

        <div class="cart-summary">
            <h2 data-i18n="cart_summary_title">Resumo do Pedido</h2>
            <div class="summary-row">
                <span data-i18n="cart_subtotal">Subtotal:</span>
                <span>R$ {{total}}</span>
            </div>
            <div class="summary-row total">
                <span data-i18n="cart_total">Total:</span>
                <span>R$ {{total}}</span>
            </div>
            <button id="showPaymentMethods" class="btn btn-success btn-block cart-action-gap" data-i18n="cart_checkout">Finalizar Compra</button>
            <a href="/cursos" class="btn btn-primary btn-block" data-i18n="cart_viewcourses">Ver Cursos</a>
            <a href="/carrinho?clear=1" class="btn btn-outline-secondary btn-block cart-action-top" data-i18n="cart_clear">Limpar Carrinho</a>

            <div id="paymentMethodsBox" class="payment-methods-box">
                <h3 class="payment-methods-title" data-i18n="cart_payment_methods">Formas de Pagamento</h3>
                <div id="paymentMethodsList" class="payment-methods-list"></div>
                <a href="/checkout" class="btn btn-success btn-block cart-action-top" data-i18n="cart_go_payment">Ir para pagamento</a>
            </div>
        </div>

        {{else}}
        <div class="empty-cart">
            <p data-i18n="cart_empty">Seu carrinho está vazio.</p>
            <a href="/" class="btn btn-primary" data-i18n="cart_viewcourses">Ver Cursos</a>
        </div>
        {{/if}}
    </div>

    {{#if hasItems}}
    <script>
        (function () {
            const t = (key, fallback) => {
                if (typeof window.translateKey === 'function') {
                    return window.translateKey(key) || fallback;
                }
                return fallback;
            };

            const button = document.getElementById('showPaymentMethods');
            const box = document.getElementById('paymentMethodsBox');
            const list = document.getElementById('paymentMethodsList');
            const total = Number('{{totalNumber}}') || 0;

            if (!button || !box || !list || total <= 0) return;

            const renderPaymentLines = (formas) => {
                const cards = [];
                formas.forEach((forma) => {
                    if (forma.tipo === 'pix') {
                        cards.push({
                            classe: 'payment-card-pix',
                            icone: '⚡',
                            titulo: t('pm_pix_title', 'PIX'),
                            descricao: t('pm_pix_desc', 'Pagamento instantâneo com confirmação imediata.')
                        });
                    }

                    if (forma.tipo === 'boleto') {
                        cards.push({
                            classe: 'payment-card-boleto',
                            icone: '🧾',
                            titulo: t('pm_boleto_title', 'Boleto'),
                            descricao: t('pm_boleto_desc', 'Pagamento no boleto bancário.')
                        });
                    }

                    if (forma.tipo === 'cartao_credito' && forma.regras) {
                        cards.push({
                            classe: 'payment-card-cartao',
                            icone: '💳',
                            titulo: t('pm_cc_noint_title', 'Cartão de Crédito — Sem Juros'),
                            descricao: t('pm_cc_noint_desc', 'À vista ou parcelado em até 4x sem juros.')
                        });
                        cards.push({
                            classe: 'payment-card-cartao',
                            icone: '💳',
                            titulo: t('pm_cc_int_title', 'Cartão de Crédito — Com Juros'),
                            descricao: t('pm_cc_int_desc', 'Parcelado de 5x até 10x com juros.')
                        });
                    }
                });

                list.innerHTML = cards.map((card) => `
                    <div class="payment-method-card ${card.classe}">
                        <div class="payment-icon">${card.icone}</div>
                        <div>
                            <div class="payment-card-title">${card.titulo}</div>
                            <div class="payment-card-desc">${card.descricao}</div>
                        </div>
                    </div>
                `).join('');
            };

            button.addEventListener('click', async () => {
                if (box.style.display === 'block') {
                    box.style.display = 'none';
                    return;
                }

                try {
                    const response = await fetch(`/api/pagamentos?valor=${total}`);
                    if (!response.ok) throw new Error('Falha ao obter pagamentos');
                    const data = await response.json();
                    renderPaymentLines(data.formasPagamento || []);
                    box.style.display = 'block';
                } catch (error) {
                    list.innerHTML = `<div class="payment-load-error">${t('pm_load_error', 'Não foi possível carregar as formas de pagamento agora.')}</div>`;
                    box.style.display = 'block';
                }
            });
        })();
    </script>
    {{/if}}

</section>

</html>