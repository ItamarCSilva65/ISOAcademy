<div class="product-detail-container">
    <div class="product-image">
        <img src="{{course.img}}" alt="{{t course.nome lang}}">
    </div>
    <div class="product-info">
        <div class="breadcrumbs">
            <a href="/">Home</a> > <a href="/cursos">Cursos</a> > <span>{{t course.nome lang}}</span>
        </div>
        
        <h1>{{t course.nome lang}}</h1>
        <h2 class="subtitle">{{t course.titulo_completo lang}}</h2>
        <p class="description">{{t course.desc lang}}</p>
        
        <ul class="benefits-list">
            <li>✓ Certificado válido em todo território nacional</li>
            <li>✓ Acesso vitalício às aulas</li>
            <li>✓ Material de apoio em PDF</li>
        </ul>
        
        <div class="purchase-box">
            <span class="big-price">{{formatCurrency course.preco}}</span>
            <p class="payment-info">Pagamento único. Sem mensalidades.</p>
            
            <a href="/carrinho?add={{course.id}}" class="btn btn-success btn-large">Matricular-se Agora</a>
        </div>
        
        <a href="/" class="back-link">← Voltar para a loja</a>
    </div>
</div>

